{
  "entities": {
    "User": {
      "title": "User",
      "description": "A real estate agent using the LeadPilot platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "createdAt", "updatedAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential client.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["hot", "warm", "cold"] },
        "potentialRevenue": { "type": "number" },
        "lastContactedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "phone", "status", "createdAt", "updatedAt"]
    },
    "FollowUp": {
      "title": "FollowUp",
      "description": "A scheduled task or AI-generated follow-up suggestion.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "leadId": { "type": "string" },
        "messageDraft": { "type": "string" },
        "dueAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "sent", "dismissed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "leadId", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Stores leads belonging to users."
    },
    "followups/{followupId}": {
      "schema": "FollowUp",
      "description": "Stores follow up tasks."
    }
  }
}
